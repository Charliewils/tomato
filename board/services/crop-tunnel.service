[Unit]
Description=Cloudflare quick tunnel for crop-web (public access on any network)
After=network-online.target crop-web.service
Wants=network-online.target

[Service]
ExecStart=/userdata/cloudflared tunnel --url http://localhost:8080 --no-autoupdate
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
